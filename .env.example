# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must NEVER be committed.

# --- Supabase (Phase 2) -----------------------------------------------------
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY, never exposed to the browser. (Settings → API)
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin dashboard --------------------------------------------------------
# Password you'll type to view orders at /admin. Choose something strong.
ADMIN_PASSWORD=change-me

# --- bKash (optional, for automatic payments) -------------------------------
# Leave blank to use the MANUAL bKash advance flow (works with no merchant acct).
# Fill these once you have a bKash MERCHANT account (needs a registered business).
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
